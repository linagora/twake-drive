.scribe-result-panel
  padding 16px
  min-width 280px

.scribe-result-header
  display flex
  align-items center
  justify-content space-between
  margin-bottom 8px

.scribe-result-text
  max-height 300px
  overflow-y auto
  padding 12px
  background-color #f5f5f5
  border-radius 4px
  font-family monospace
  font-size 13px
  line-height 1.5
  white-space pre-wrap
  margin-bottom 12px

.scribe-result-actions
  display flex
  justify-content flex-end
  align-items center
  gap 8px
