.scribe-result-panel
  padding 16px
  min-width 300px
  max-width 800px
  width fit-content
  border-radius 8px
  box-shadow 0 4px 20px rgba(0,0,0,0.15)

.scribe-result-header
  display flex
  align-items center
  justify-content space-between
  margin-bottom 8px

.scribe-result-text
  max-height min(500px, 70vh)
  min-height 48px
  overflow-y auto
  padding 12px
  border-radius 4px
  font-family inherit
  font-size 13px
  line-height 1.5
  white-space normal
  margin-bottom 12px
  transition max-height 200ms ease-out

.scribe-result-actions
  display flex
  justify-content flex-end
  align-items center
  gap 8px

.scribe-loading-panel
  padding 32px 48px
  display flex
  flex-direction column
  align-items center
  justify-content center
  gap 16px
  min-width 250px
  border-radius 8px
  box-shadow 0 4px 20px rgba(0,0,0,0.15)

.scribe-loading-message
  text-align center
  font-style italic

