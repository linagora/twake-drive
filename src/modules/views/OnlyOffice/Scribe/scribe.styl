.scribe-result-panel
  padding 16px
  min-width 300px
  max-width 560px
  width fit-content

.scribe-result-header
  display flex
  align-items center
  justify-content space-between
  margin-bottom 8px

.scribe-result-text
  max-height min(400px, 60vh)
  min-height 48px
  overflow-y auto
  padding 12px
  border-radius 4px
  font-family monospace
  font-size 13px
  line-height 1.5
  white-space pre-wrap
  margin-bottom 12px
  transition max-height 200ms ease-out

.scribe-result-actions
  display flex
  justify-content flex-end
  align-items center
  gap 8px

